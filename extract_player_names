#!/bin/bash

# Load the config.yml file
# parse_yaml function code credit Stefan Farestam: https://stackoverflow.com/questions/5014632/how-can-i-parse-a-yaml-file-from-a-linux-shell-script/21189044#21189044
function parse_yaml {
   local prefix=$2
   local s='[[:space:]]*' w='[a-zA-Z0-9_]*' fs=$(echo @|tr @ '\034')
   sed -ne "s|^\($s\):|\1|" \
        -e 's|`||g;s|\$||g;' \
        -e "s|^\($s\)\($w\)$s:$s[\"']\(.*\)[\"']$s\$|\1$fs\2$fs\3|p" \
        -e "s|^\($s\)\($w\)$s:$s\(.*\)$s\$|\1$fs\2$fs\3|p"  $1 |
   awk -F$fs '{
      indent = length($1)/2;
      vname[indent] = $2;
      for (i in vname) {if (i > indent) {delete vname[i]}}
      if (length($3) > 0) {
         vn=""; for (i=0; i<indent; i++) {vn=(vn)(vname[i])("_")}
         printf("%s%s%s=\"%s\"\n", "'$prefix'",vn, $2, $3);
      }
   }'
}

eval $(parse_yaml /home/mcserver/minecraft/mc_backup/config.yml)

# Change the directory to the log folder
cd "$CONSTANTS_LOG_PATH"

# Initialize associative arrays for player metrics
declare -A player_counts
declare -A player_last_left_times
declare -A player_last_left_epoch_times
declare -A player_total_play_seconds
declare -A player_open_join_epoch

format_duration_hhmmss() {
    local total_seconds="$1"
    local hours=$(( total_seconds / 3600 ))
    local minutes=$(( (total_seconds % 3600) / 60 ))
    local seconds=$(( total_seconds % 60 ))
    printf "%02d:%02d:%02d" "$hours" "$minutes" "$seconds"
}

event_file=$(mktemp)
seq_num=0

# Compress the latest.log file
gzip -c latest.log > latest.log.gz

# Find and sort the .gz files
log_files=$(find . -name '[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]-*.log.gz' | sort)

# Loop through each YYYY-MM-DD-X.log.gz file and latest.log.gz
for file in $log_files latest.log.gz; do
    # Extract the date from the filename so both old and new log timestamp formats are supported
    file_date=$(echo "$file" | grep -oE '[0-9]{4}-[0-9]{2}-[0-9]{2}')
    if [[ -z "$file_date" ]]; then
        file_date=$(date +"%Y-%m-%d")
    fi

    while read -r line; do
        if [[ $line =~ ^\[([0-9]{2}:[0-9]{2}:[0-9]{2})\] ]]; then
            time=${BASH_REMATCH[1]}
        elif [[ $line =~ ^\[([0-9]{2}[A-Za-z]{3}[0-9]{4}\ [0-9]{2}:[0-9]{2}:[0-9]{2}\.[0-9]{3})\] ]]; then
            time=${BASH_REMATCH[1]:10:8}
        else
            continue
        fi

        datetime="$file_date $time"
        epoch_time=$(date -d "$datetime" "+%s")

        if [[ $line =~ [[:alnum:]_]+\ joined\ the\ game ]]; then
            name=$(echo "$line" | grep -oE '[[:alnum:]_]+ joined the game' | awk '{print $1}')
            seq_num=$(( seq_num + 1 ))
            echo "$epoch_time|$seq_num|$name|joined|$datetime" >> "$event_file"
        elif [[ $line =~ [[:alnum:]_]+\ left\ the\ game ]]; then
            name=$(echo "$line" | grep -oE '[[:alnum:]_]+ left the game' | awk '{print $1}')
            seq_num=$(( seq_num + 1 ))
            echo "$epoch_time|$seq_num|$name|left|$datetime" >> "$event_file"
        fi
    done < <(zcat "$file" | grep -E '[[:alnum:]_]+ (joined|left) the game')
done

# Delete the compressed copy of latest.log
rm latest.log.gz

# Process normalized events in chronological order per player
while IFS='|' read -r epoch_time _ name event_type datetime; do
    if [[ "$event_type" == "joined" ]]; then
        if [[ -z "${player_open_join_epoch[$name]}" ]]; then
            player_open_join_epoch["$name"]="$epoch_time"
        fi
    elif [[ "$event_type" == "left" ]]; then
        player_counts["$name"]=$(( player_counts["$name"] + 1 ))
        player_last_left_times["$name"]="$datetime"
        player_last_left_epoch_times["$name"]="$epoch_time"

        if [[ -n "${player_open_join_epoch[$name]}" ]]; then
            join_epoch_time="${player_open_join_epoch[$name]}"
            if (( epoch_time >= join_epoch_time )); then
                session_seconds=$(( epoch_time - join_epoch_time ))
                player_total_play_seconds["$name"]=$(( ${player_total_play_seconds[$name]:-0} + session_seconds ))
            fi
            unset player_open_join_epoch["$name"]
        fi
    fi
done < <(sort -t '|' -k1,1n -k2,2n "$event_file")

rm "$event_file"

# Find the latest player_last_left_epoch_time for player names with a count of at least PREFS_MINIMUM_PLAYS
most_recent_left_epoch_time=0
most_recent_left_name=" "
for name in "${!player_counts[@]}"; do
    count="${player_counts[$name]}"
    last_left_epoch_time="${player_last_left_epoch_times[$name]}"
    if (( count >= PREFS_MINIMUM_PLAYS )) && (( last_left_epoch_time > most_recent_left_epoch_time )); then
        most_recent_left_epoch_time="$last_left_epoch_time"
        most_recent_left_name="$name"
    fi
done

# Convert the most recent left epoch time to a human-readable format
most_recent_left_datetime=$(date -d "@$most_recent_left_epoch_time" "+%Y-%m-%d %H:%M:%S")

# Format the player metrics into a simplified table
formatted_names=()
for name in "${!player_counts[@]}"; do
    count="${player_counts[$name]}"
    total_play_seconds="${player_total_play_seconds[$name]:-0}"
    total_play_time=$(format_duration_hhmmss "$total_play_seconds")
    last_left_time="${player_last_left_times[$name]}"
    formatted_names+=("$name|$count|$total_play_time|$last_left_time")
done

# Print the header and formatted player rows in a single aligned table
{
    echo "Player Name|Count|Total Play Time|Most Recent Left Time"
    for name in "${formatted_names[@]}"; do
        echo "$name"
    done | sort -t '|' -k2,2nr
} | column -t -s '|'

# Print the most recent left datetime
echo "Most recent left datetime for player with at least $PREFS_MINIMUM_PLAYS counts is: $most_recent_left_name at $most_recent_left_datetime"